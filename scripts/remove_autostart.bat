@echo off
REM Скрипт для удаления автозапуска бота из Task Scheduler
REM Требует прав администратора

title GPT Bot - Удаление автозапуска

echo ========================================
echo   Удаление автозапуска GPT Bot
echo ========================================
echo.

REM Проверяем права администратора
net session >nul 2>&1
if %errorlevel% neq 0 (
    echo ОШИБКА: Этот скрипт требует прав администратора!
    echo Запустите его от имени администратора (правой кнопкой мыши -^> "Запуск от имени администратора")
    pause
    exit /b 1
)

echo Удаление задачи автозапуска...
schtasks /delete /tn "GPT Bot - Auto Start" /f

if %errorlevel% neq 0 (
    echo.
    echo Задача не найдена или уже удалена.
) else (
    echo.
    echo Автозапуск успешно удален!
)

echo.
pause

